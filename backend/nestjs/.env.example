# Prisma (Supabase Postgres or local Postgres)
DATABASE_URL=postgresql://postgres:password@localhost:5432/edumaa
DIRECT_URL=postgresql://postgres:password@localhost:5432/edumaa

# Supabase (auth/storage/realtime)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (cache/pubsub/queues)
REDIS_URL=redis://localhost:6379

# Internal Django admin API bridge
DJANGO_INTERNAL_API_URL=http://localhost:8000/admin-api
INTERNAL_API_TOKEN=replace-with-same-token-used-by-django

# Payments and video webhooks
STRIPE_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_TUTOR_SUBSCRIPTION_PRICE_ID=
STRIPE_SCHOOL_SUBSCRIPTION_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
MUX_WEBHOOK_SECRET=

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Queue dashboard auth
QUEUES_UI_USER=admin
QUEUES_UI_PASS=password
