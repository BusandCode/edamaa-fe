generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -------------------------
// Prisma schema for edamaa
// -------------------------
// The schema models below are intentionally minimal for the scaffold.
// Add fields, indexes and constraints as the domain requires.

model User {
  // Primary key for the user record; auto-incrementing integer.
  id        Int      @id @default(autoincrement())

  // Email is unique and will be used for authentication in many flows.
  email     String   @unique

  // Optional display name for the user.
  name      String?

  // Role allows simple RBAC: 'student', 'tutor', 'admin', etc.
  role      String   @default("student")

  // Creation timestamp for auditing and sorting.
  createdAt DateTime @default(now())

  // Relation to Enrollment model.
  enrollments Enrollment[]

  // Multi-role account access for student/tutor/school/admin personas.
  accountRoles       UserRole[]
  roleChangeRequests RoleChangeRequest[]

  // Payment domain relations.
  paymentMethods      PaymentMethod[]
  paymentTransactions PaymentTransaction[]

  // Teaching subscription relation (tutor/school monetization).
  teachingSubscriptions TeachingSubscription[]

  // School finance domain (marketplace payout model).
  schoolFinanceAccount  SchoolFinanceAccount?
  schoolFeePayments     SchoolFeePayment[]   @relation("SchoolFeePaymentPayer")
  schoolFeeInvoices     SchoolFeeInvoice[]   @relation("SchoolFeeInvoiceStudent")
  schoolScheduleSessions SchoolScheduleSession[] @relation("SchoolScheduleOwner")
  schoolScheduleNotifications SchoolScheduleNotification[] @relation("SchoolScheduleNotificationOwner")
}

model School {
  id      Int      @id @default(autoincrement())
  name    String
  courses Course[]
}

model Course {
  id          Int          @id @default(autoincrement())
  title       String
  school      School?      @relation(fields: [schoolId], references: [id])
  schoolId    Int?
  enrollments Enrollment[]
}

model Enrollment {
  id       Int    @id @default(autoincrement())
  user     User   @relation(fields: [userId], references: [id])
  userId   Int
  course   Course @relation(fields: [courseId], references: [id])
  courseId Int
  role     String @default("student")
}

model UserRole {
  id            Int               @id @default(autoincrement())
  publicId      String            @unique
  user          User              @relation(fields: [userId], references: [id])
  userId        Int
  role          AccountRole
  status        AccountRoleStatus @default(ACTIVE)
  isDefault     Boolean           @default(false)
  requestedAt   DateTime          @default(now())
  activatedAt   DateTime?
  deactivatedAt DateTime?
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([userId, role])
  @@index([userId, status, isDefault])
  @@index([role, status, createdAt])
}

model RoleChangeRequest {
  id              Int                     @id @default(autoincrement())
  publicId        String                  @unique
  user            User                    @relation(fields: [userId], references: [id])
  userId          Int
  targetRole      AccountRole
  status          RoleChangeRequestStatus @default(PENDING)
  note            String?
  requestPayload  Json?
  reviewedByEmail String?
  reviewedAt      DateTime?
  rejectionReason String?
  metadata        Json?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([userId, status, createdAt])
  @@index([targetRole, status, createdAt])
}

enum PaymentMethodType {
  CARD
  BANK
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  UPCOMING
}

enum PaymentCategory {
  TUITION
  ACCOMMODATION
  FEES
  MATERIALS
}

enum PaymentProvider {
  LOCAL
  STRIPE
}

enum SubscriptionRole {
  TUTOR
  SCHOOL
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

enum AccountRole {
  STUDENT
  TUTOR
  SCHOOL
  ADMIN
}

enum AccountRoleStatus {
  ACTIVE
  INACTIVE
}

enum RoleChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum SchoolFeeInvoiceStatus {
  DRAFT
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELED
}

enum SchoolFeePaymentStatus {
  PENDING
  SETTLED
  FAILED
  REFUNDED
}

enum SchoolPayoutStatus {
  REQUESTED
  PROCESSING
  PAID
  FAILED
  CANCELED
}

enum SchoolFeeReminderType {
  DUE_SOON
  OVERDUE
}

enum SchoolFeeReminderChannel {
  IN_APP
  EMAIL
}

enum SchoolFeeReminderDispatchStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

model PaymentMethod {
  id                Int               @id @default(autoincrement())
  publicId          String            @unique
  user              User              @relation(fields: [userId], references: [id])
  userId            Int
  type              PaymentMethodType
  label             String
  last4             String
  isDefault         Boolean           @default(false)
  provider          PaymentProvider   @default(LOCAL)
  providerReference String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId, isDefault])
}

model PaymentTransaction {
  id                Int             @id @default(autoincrement())
  publicId          String          @unique
  user              User            @relation(fields: [userId], references: [id])
  userId            Int
  description       String
  amountMinor       Int
  currency          String          @default("NGN")
  status            PaymentStatus   @default(PENDING)
  category          PaymentCategory
  dueAt             DateTime?
  paidAt            DateTime?
  receiptRef        String?
  provider          PaymentProvider @default(LOCAL)
  providerReference String?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([userId, status, createdAt])
  @@index([userId, dueAt])
}

model TeachingSubscription {
  id                 Int                @id @default(autoincrement())
  publicId           String             @unique
  user               User               @relation(fields: [userId], references: [id])
  userId             Int
  role               SubscriptionRole
  status             SubscriptionStatus @default(INACTIVE)
  planCode           String             @default("edamaa-pro-monthly")
  priceId            String?
  stripeCustomerId   String?
  stripeSubscriptionId String?
  checkoutSessionId  String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  verified3dAt       DateTime?
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([userId, role])
  @@index([status, currentPeriodEnd])
  @@index([stripeSubscriptionId])
}

model SchoolFinanceAccount {
  id                      Int      @id @default(autoincrement())
  publicId                String   @unique
  schoolUser              User     @relation(fields: [schoolUserId], references: [id])
  schoolUserId            Int      @unique
  currency                String   @default("NGN")
  pendingMinor            Int      @default(0)
  availableMinor          Int      @default(0)
  onHoldMinor             Int      @default(0)
  lifetimeGrossMinor      Int      @default(0)
  lifetimeNetMinor        Int      @default(0)
  totalWithdrawnMinor     Int      @default(0)
  stripeConnectedAccountId String?
  payoutsEnabled          Boolean  @default(false)
  chargesEnabled          Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  feePlans SchoolFeePlan[]
  invoices SchoolFeeInvoice[]
  payments SchoolFeePayment[]
  payouts  SchoolPayout[]
  payoutLedgerEntries SchoolPayoutLedgerEntry[]
}

model SchoolFeePlan {
  id          Int                @id @default(autoincrement())
  publicId    String             @unique
  account     SchoolFinanceAccount @relation(fields: [accountId], references: [id])
  accountId   Int
  title       String
  description String?
  amountMinor Int
  currency    String             @default("NGN")
  dueDays     Int?
  isActive    Boolean            @default(true)
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  invoices SchoolFeeInvoice[]

  @@index([accountId, isActive, createdAt])
}

model SchoolScheduleSession {
  id               Int      @id @default(autoincrement())
  publicId         String   @unique
  schoolUser       User     @relation("SchoolScheduleOwner", fields: [schoolUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  schoolUserId     Int
  title            String
  subject          String
  instructor       String
  startAt          DateTime
  endAt            DateTime
  durationMinutes  Int
  expectedStudents Int      @default(0)
  roomCode         String
  notes            String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([schoolUserId, startAt])
  @@index([schoolUserId, instructor, startAt])
  @@index([schoolUserId, roomCode, startAt])
}

model SchoolScheduleNotification {
  id               Int      @id @default(autoincrement())
  publicId         String   @unique
  schoolUser       User     @relation("SchoolScheduleNotificationOwner", fields: [schoolUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  schoolUserId     Int
  kind             String
  sessionPublicId  String
  sessionTitle     String
  subject          String
  instructor       String
  roomCode         String
  startAt          DateTime
  assignedTutorEmail String?
  department       String?
  classGroup       String?
  audienceTag      String?
  targetEmail      String?
  tutorJoinLink    String?
  tutorJoinCode    String?
  tutorJoinToken   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  reads SchoolScheduleNotificationRead[]

  @@index([schoolUserId, createdAt])
  @@index([targetEmail, createdAt])
  @@index([kind, createdAt])
  @@index([sessionPublicId, createdAt])
}

model SchoolScheduleNotificationRead {
  id             Int      @id @default(autoincrement())
  publicId       String   @unique
  notification   SchoolScheduleNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  notificationId Int
  userEmail      String
  readAt         DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userEmail, notificationId])
  @@index([userEmail, createdAt])
  @@index([notificationId, createdAt])
}

model SchoolFeeInvoice {
  id                    Int                  @id @default(autoincrement())
  publicId              String               @unique
  account               SchoolFinanceAccount @relation(fields: [accountId], references: [id])
  accountId             Int
  plan                  SchoolFeePlan?       @relation(fields: [planId], references: [id])
  planId                Int?
  studentUser           User?                @relation("SchoolFeeInvoiceStudent", fields: [studentUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  studentUserId         Int?
  studentEmail          String
  studentName           String?
  title                 String
  description           String?
  amountMinor           Int
  currency              String               @default("NGN")
  status                SchoolFeeInvoiceStatus @default(PENDING)
  dueAt                 DateTime?
  paidAt                DateTime?
  stripeCheckoutSessionId String?            @unique
  stripePaymentIntentId String?
  metadata              Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  payments SchoolFeePayment[]
  reminderDispatches SchoolFeeReminderDispatch[]

  @@index([accountId, status, createdAt])
  @@index([studentEmail, status, dueAt])
  @@index([studentUserId, status, dueAt])
}

model SchoolFeeInvoiceNotificationRead {
  id            Int      @id @default(autoincrement())
  publicId      String   @unique
  invoicePublicId String?
  userEmail     String
  notificationId String
  kind          String
  readAt        DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userEmail, notificationId])
  @@index([invoicePublicId, createdAt])
  @@index([userEmail, createdAt])
}

model SchoolFeeReminderDispatch {
  id             Int                           @id @default(autoincrement())
  publicId       String                        @unique
  invoice        SchoolFeeInvoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId      Int
  invoicePublicId String
  accountId      Int
  studentEmail   String
  reminderType   SchoolFeeReminderType
  channel        SchoolFeeReminderChannel
  status         SchoolFeeReminderDispatchStatus @default(QUEUED)
  attemptCount   Int                           @default(0)
  nextRetryAt    DateTime?
  lastError      String?
  reminderDate   DateTime
  sentAt         DateTime?
  failureReason  String?
  metadata       Json?
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt

  @@unique([invoiceId, studentEmail, reminderType, channel, reminderDate], name: "SchoolFeeReminderDispatch_invoice_student_type_channel_date_key")
  @@index([accountId, createdAt])
  @@index([studentEmail, createdAt])
  @@index([channel, status, createdAt])
  @@index([channel, status, nextRetryAt, createdAt])
}

model SchoolFeePayment {
  id                Int                   @id @default(autoincrement())
  publicId          String                @unique
  account           SchoolFinanceAccount  @relation(fields: [accountId], references: [id])
  accountId         Int
  invoice           SchoolFeeInvoice      @relation(fields: [invoiceId], references: [id])
  invoiceId         Int
  payerUser         User?                 @relation("SchoolFeePaymentPayer", fields: [payerUserId], references: [id])
  payerUserId       Int?
  payerEmail        String
  grossAmountMinor  Int
  platformFeeMinor  Int                   @default(0)
  processingFeeMinor Int                  @default(0)
  netAmountMinor    Int
  currency          String                @default("NGN")
  provider          PaymentProvider       @default(LOCAL)
  providerReference String?               @unique
  status            SchoolFeePaymentStatus @default(PENDING)
  settledAt         DateTime?
  metadata          Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([accountId, status, createdAt])
  @@index([invoiceId, status, createdAt])
}

model SchoolPayout {
  id                Int               @id @default(autoincrement())
  publicId          String            @unique
  account           SchoolFinanceAccount @relation(fields: [accountId], references: [id])
  accountId         Int
  amountMinor       Int
  currency          String            @default("NGN")
  status            SchoolPayoutStatus @default(REQUESTED)
  provider          PaymentProvider   @default(LOCAL)
  providerReference String?
  requestedAt       DateTime          @default(now())
  processedAt       DateTime?
  failureReason     String?
  metadata          Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  ledgerEntries SchoolPayoutLedgerEntry[]

  @@index([accountId, status, createdAt])
}

model SchoolPayoutLedgerEntry {
  id            Int                  @id @default(autoincrement())
  publicId      String               @unique
  account       SchoolFinanceAccount @relation(fields: [accountId], references: [id])
  accountId     Int
  payout        SchoolPayout         @relation(fields: [payoutId], references: [id])
  payoutId      Int
  previousStatus SchoolPayoutStatus?
  nextStatus    SchoolPayoutStatus
  amountMinor   Int
  currency      String               @default("NGN")
  note          String?
  metadata      Json?
  createdAt     DateTime             @default(now())

  @@index([accountId, createdAt])
  @@index([payoutId, createdAt])
}

// Webhook events persisted for audit and safe retry processing. Store provider
// metadata and raw JSON payload. Background workers set `processed=true` when
// handling succeeds.
model WebhookEvent {
  id         Int      @id @default(autoincrement())
  provider   String
  eventType  String   @default("")
  signature  String   @default("")
  payload    Json
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// Stores call signaling events for call audit trails and missed-call analytics.
// These rows are written by the realtime service and can be queried by admin/UIs.
model CallSignalEvent {
  id              Int      @id @default(autoincrement())
  eventId         String?  @unique
  channel         String
  event           String
  callId          String?
  studentId       Int?
  senderRole      String?
  senderLabel     String?
  mode            String?
  reason          String?
  durationSeconds Int?
  payload         Json
  publishedAt     DateTime
  createdAt       DateTime @default(now())

  @@index([channel, event, createdAt])
  @@index([studentId, createdAt])
  @@index([callId, createdAt])
}

// Stores paid resource unlock purchases so students keep access after server
// restarts. This is intentionally lightweight and keyed by resource/email.
model ResourcePurchase {
  id         Int      @id @default(autoincrement())
  publicId   String   @unique
  resourceId String
  buyerEmail String
  amountMinor Int     @default(0)
  purchasedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([resourceId, buyerEmail])
  @@index([buyerEmail, purchasedAt])
  @@index([resourceId, purchasedAt])
}

// Stores school-curated free-library recommendations so pinned books survive
// server restarts and can be targeted to specific student lanes.
model ResourceFreeBookRecommendation {
  id                Int      @id @default(autoincrement())
  publicId          String   @unique
  bookId            String
  source            String
  sourceLabel       String
  title             String
  authors           Json
  description       String
  subject           String
  coverImageUrl     String?
  actionUrl         String
  actionLabel       String
  accessLabel       String
  licenseLabel      String
  publishedAt       String?
  curatorEmail      String
  curatorName       String
  curatorRole       String   @default("school")
  note              String?
  targetSchoolLevel String?
  targetDepartment  String?
  targetClassGroup  String?
  recommendedAt     DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([bookId, curatorEmail])
  @@index([curatorEmail, recommendedAt])
  @@index([bookId, recommendedAt])
}

// Stores reusable school-side audience targets for free-book recommendations.
model ResourceFreeBookAudiencePreset {
  id                Int      @id @default(autoincrement())
  publicId          String   @unique
  workspaceKey      String
  workspaceLabel    String?
  curatorEmail      String
  curatorName       String
  label             String
  targetSchoolLevel String?
  targetDepartment  String?
  targetClassGroup  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([workspaceKey, label])
  @@index([workspaceKey, updatedAt])
  @@index([curatorEmail, updatedAt])
}
