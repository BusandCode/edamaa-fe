generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -------------------------
// Prisma schema for edamaa
// -------------------------
// The schema models below are intentionally minimal for the scaffold.
// Add fields, indexes and constraints as the domain requires.

model User {
  // Primary key for the user record; auto-incrementing integer.
  id        Int      @id @default(autoincrement())

  // Email is unique and will be used for authentication in many flows.
  email     String   @unique

  // Optional display name for the user.
  name      String?

  // Role allows simple RBAC: 'student', 'tutor', 'admin', etc.
  role      String   @default("student")

  // Creation timestamp for auditing and sorting.
  createdAt DateTime @default(now())

  // Relation to Enrollment model.
  enrollments Enrollment[]

  // Payment domain relations.
  paymentMethods      PaymentMethod[]
  paymentTransactions PaymentTransaction[]

  // Teaching subscription relation (tutor/school monetization).
  teachingSubscriptions TeachingSubscription[]
}

model School {
  id      Int      @id @default(autoincrement())
  name    String
  courses Course[]
}

model Course {
  id          Int          @id @default(autoincrement())
  title       String
  school      School?      @relation(fields: [schoolId], references: [id])
  schoolId    Int?
  enrollments Enrollment[]
}

model Enrollment {
  id       Int    @id @default(autoincrement())
  user     User   @relation(fields: [userId], references: [id])
  userId   Int
  course   Course @relation(fields: [courseId], references: [id])
  courseId Int
  role     String @default("student")
}

enum PaymentMethodType {
  CARD
  BANK
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  UPCOMING
}

enum PaymentCategory {
  TUITION
  ACCOMMODATION
  FEES
  MATERIALS
}

enum PaymentProvider {
  LOCAL
  STRIPE
}

enum SubscriptionRole {
  TUTOR
  SCHOOL
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

model PaymentMethod {
  id                Int               @id @default(autoincrement())
  publicId          String            @unique
  user              User              @relation(fields: [userId], references: [id])
  userId            Int
  type              PaymentMethodType
  label             String
  last4             String
  isDefault         Boolean           @default(false)
  provider          PaymentProvider   @default(LOCAL)
  providerReference String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId, isDefault])
}

model PaymentTransaction {
  id                Int             @id @default(autoincrement())
  publicId          String          @unique
  user              User            @relation(fields: [userId], references: [id])
  userId            Int
  description       String
  amountMinor       Int
  currency          String          @default("NGN")
  status            PaymentStatus   @default(PENDING)
  category          PaymentCategory
  dueAt             DateTime?
  paidAt            DateTime?
  receiptRef        String?
  provider          PaymentProvider @default(LOCAL)
  providerReference String?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([userId, status, createdAt])
  @@index([userId, dueAt])
}

model TeachingSubscription {
  id                 Int                @id @default(autoincrement())
  publicId           String             @unique
  user               User               @relation(fields: [userId], references: [id])
  userId             Int
  role               SubscriptionRole
  status             SubscriptionStatus @default(INACTIVE)
  planCode           String             @default("edamaa-pro-monthly")
  priceId            String?
  stripeCustomerId   String?
  stripeSubscriptionId String?
  checkoutSessionId  String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  verified3dAt       DateTime?
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([userId, role])
  @@index([status, currentPeriodEnd])
  @@index([stripeSubscriptionId])
}

// Webhook events persisted for audit and safe retry processing. Store provider
// metadata and raw JSON payload. Background workers set `processed=true` when
// handling succeeds.
model WebhookEvent {
  id         Int      @id @default(autoincrement())
  provider   String
  eventType  String   @default("")
  signature  String   @default("")
  payload    Json
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// Stores call signaling events for call audit trails and missed-call analytics.
// These rows are written by the realtime service and can be queried by admin/UIs.
model CallSignalEvent {
  id              Int      @id @default(autoincrement())
  eventId         String?  @unique
  channel         String
  event           String
  callId          String?
  studentId       Int?
  senderRole      String?
  senderLabel     String?
  mode            String?
  reason          String?
  durationSeconds Int?
  payload         Json
  publishedAt     DateTime
  createdAt       DateTime @default(now())

  @@index([channel, event, createdAt])
  @@index([studentId, createdAt])
  @@index([callId, createdAt])
}
