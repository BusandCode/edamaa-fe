{
    "name": "@cloudflare/realtimekit",
    "version": "1.4.0",
    "description": "A real-time video and audio SDK for building custom, collaborative communication experiences.",
    "main": "./dist/index.cjs.js",
    "module": "./dist/index.es.js",
    "exports": {
        ".": {
            "import": "./dist/index.es.js",
            "require": "./dist/index.cjs.js",
            "types": "./dist/index.d.ts",
            "typesVersions": {
                "<4.0": {
                    "*": [
                        "./dist/ts3.4/*"
                    ]
                }
            }
        },
        "./inlined": {
            "default": "./dist/browser.js",
            "types": "./dist/index.d.ts",
            "typesVersions": {
                "<4.0": {
                    "*": [
                        "./dist/ts3.4/*"
                    ]
                }
            }
        },
        "./compatible": {
            "import": "./dist/index.es5.js",
            "types": "./dist/index.d.ts",
            "typesVersions": {
                "<4.0": {
                    "*": [
                        "./dist/ts3.4/*"
                    ]
                }
            }
        },
        "./e2ee": {
            "import": "./dist/EncryptionManager.es.js",
            "default": "./dist/EncryptionManager.cjs",
            "types": "./dist/EncryptionManager.d.ts",
            "typesVersions": {
                "<4.0": {
                    "*": [
                        "./dist/ts3.4/*"
                    ]
                }
            }
        },
        "./mock": {
            "import": "./dist/ClientMock.es.js",
            "require": "./dist/ClientMock.cjs.js",
            "types": "./dist/ClientMock.d.ts",
            "typesVersions": {
                "<4.0": {
                    "*": [
                        "./dist/ts3.4/*"
                    ]
                }
            }
        }
    },
    "react-native": "./dist/index.rn.js",
    "types": "./dist/index.d.ts",
    "typesVersions": {
        "<4.0": {
            "*": [
                "./dist/ts3.4/*"
            ]
        }
    },
    "bugs": {
        "url": "https://community.cloudflare.com"
    },
    "homepage": "https://realtime.cloudflare.com",
    "private": false,
    "dependencies": {
        "@protobuf-ts/runtime": "^2.7.0",
        "bowser": "^2.11.0",
        "sdp-transform": "^2.14.1",
        "uuid": "^8.3.2",
        "worker-timers": "7.0.60"
    },
    "publishConfig": {
        "access": "public",
        "tag": "latest"
    },
    "devDependencies": {
        "@types/events": "^3.0.0",
        "@types/lodash-es": "^4.17.6",
        "@types/long": "4.0.0",
        "@types/node": "^16.0.0",
        "@types/sdp-transform": "^2.4.5",
        "@types/uuid": "^8.3.4",
        "type-fest": "^2.12.1",
        "@cloudflare/realtimekit-callstats": "8.0.0",
        "@dyteinternals/proto-entities": "2.112.0",
        "@cloudflare/realtimekit-sockrates": "0.1.2",
        "@cloudflare/realtimekit-utils": "1.0.0"
    },
    "scripts": {
        "start": "serve -s dist -l 3000 -n",
        "postpublish": "mv package.json.bak package.json"
    }
}