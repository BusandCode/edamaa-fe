# Frontend API base URL (NestJS)
VITE_API_BASE_URL=http://127.0.0.1:3001

# Optional: bootstrap Cloudflare RealtimeKit room credentials in the live classroom
# while keeping the existing Edamaa WebRTC transport as fallback.
VITE_CLOUDFLARE_REALTIMEKIT_ENABLED=false

# Supabase browser auth (required for cloud sign-in).
# Local dev fallback is available when these are unset, but production should always set both.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional production ICE server list for WebRTC.
# You can set either an array or an object with `iceServers`.
# Example:
# VITE_WEBRTC_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":["turn:turn.example.com:3478"],"username":"user","credential":"pass"}]
# VITE_WEBRTC_ICE_SERVERS_JSON={"iceServers":[{"urls":"stun:stun.l.google.com:19302"}]}
VITE_WEBRTC_ICE_SERVERS_JSON=

# Optional shorthand TURN fields (used in addition to JSON config).
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
